{
	"mcpServers": {
		"contractspec-docs": {
			"url": "https://api.contractspec.io/api/mcp/docs"
		},
		"contractspec-cli": {
			"url": "https://api.contractspec.io/api/mcp/cli"
		},
		"contractspec-internal": {
			"url": "https://api.contractspec.io/api/mcp/internal"
		},
		"contractspec-contracts": {
			"url": "https://api.contractspec.io/api/mcp/contracts"
		},
		"Alpic Documentation": {
			"url": "https://docs.alpic.ai/mcp"
		},
		"serena": {
			"command": "uvx",
			"args": [
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--context",
				"ide-assistant",
				"--enable-web-dashboard",
				"false",
				"--project",
				"."
			],
			"env": {}
		},
		"context7": {
			"command": "npx",
			"args": ["-y", "@upstash/context7-mcp"],
			"env": {}
		}
	},
	"hooks": {
		"PreToolUse": [
			{
				"type": "command",
				"matcher": "Write|Edit|MultiEdit",
				"command": "contractspec connect hook contracts-spec before-file-edit --stdin"
			},
			{
				"type": "command",
				"matcher": "Bash",
				"command": "contractspec connect hook contracts-spec before-shell-execution --stdin"
			}
		],
		"PostToolUse": [
			{
				"type": "command",
				"matcher": "Write|Edit|MultiEdit",
				"command": "contractspec connect hook contracts-spec after-file-edit --stdin"
			}
		]
	}
}

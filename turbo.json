{
	"$schema": "https://turbo.build/schema.json",
	"envMode": "strict",
	"tasks": {
		"clean": {
			"cache": false
		},
		"test": {},
		"publish:pkg": {
			"dependsOn": ["build", "^publish:pkg"],
			"cache": false,
			"env": ["NPM_CONFIG_TOKEN", "VSCE_PAT", "OVSX_PAT"]
		},
		"publish:pkg:canary": {
			"dependsOn": ["build", "^publish:pkg:canary"],
			"cache": false,
			"env": ["NPM_CONFIG_TOKEN", "VSCE_PAT", "OVSX_PAT"]
		},
		"prebuild": {
			"cache": false,
			"dependsOn": ["^prebuild"],
			"outputLogs": "new-only",
			"inputs": [
				"$TURBO_DEFAULT$",
				"package.json",
				"src/**",
				"tsdown.config.js",
				"tsdown.config.mjs",
				"tsdown.config.ts",
				"tsdown.config.cjs",
				"bun.config.js",
				"bun.config.mjs",
				"bun.config.ts",
				"bun.config.cjs",
				"!.tsconfig.contractspec-types*.json",
				"!generated/**",
				"!src/generated/**"
			],
			"outputs": []
		},
		"build": {
			"cache": true,
			"dependsOn": ["^build"],
			"outputLogs": "new-only",
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*",
				"package.json",
				"tsdown.config.js",
				"tsdown.config.mjs",
				"tsdown.config.ts",
				"tsdown.config.cjs",
				"bun.config.js",
				"bun.config.mjs",
				"bun.config.ts",
				"bun.config.cjs",
				"src/**",
				"public/**",
				"!.tsconfig.contractspec-types*.json",
				"!generated/**",
				"!src/generated/**"
			],
			"outputs": [
				"dist/**",
				"generated/**",
				".next/**",
				"!.next/cache/**",
				"src/generated/**"
			]
		},
		"build:bundle": {
			"cache": true,
			"dependsOn": ["prebuild", "^build:bundle"],
			"outputLogs": "new-only",
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*",
				"package.json",
				"tsdown.config.js",
				"tsdown.config.mjs",
				"tsdown.config.ts",
				"tsdown.config.cjs",
				"bun.config.js",
				"bun.config.mjs",
				"bun.config.ts",
				"bun.config.cjs",
				"src/**",
				"public/**",
				"!.tsconfig.contractspec-types*.json",
				"!generated/**",
				"!src/generated/**"
			],
			"outputs": [
				"dist/**",
				"generated/**",
				".next/**",
				"!.next/cache/**",
				"src/generated/**"
			]
		},
		"build:types": {
			"cache": true,
			"outputLogs": "new-only",
			"dependsOn": ["^build:types"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"public/**",
				"src/**",
				"package.json",
				"tsconfig.json",
				"tsconfig.build.json",
				"tsdown.config.js",
				"tsdown.config.mjs",
				"tsdown.config.ts",
				"tsdown.config.cjs",
				"bun.config.js",
				"bun.config.mjs",
				"bun.config.ts",
				"bun.config.cjs",
				"!.tsconfig.contractspec-types*.json",
				"!generated/**",
				"!src/generated/**"
			],
			"outputs": ["dist/**/*.d.ts", "dist/**/*.d.ts.map"]
		},
		"typecheck": {
			"cache": true,
			"outputLogs": "new-only",
			"dependsOn": ["^typecheck"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"src/**",
				"package.json",
				"tsconfig.json",
				"tsconfig.build.json",
				"!.tsconfig.contractspec-types*.json",
				"!generated/**",
				"!src/generated/**"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"docs:generate": {
			"cache": false,
			"outputLogs": "new-only"
		},
		"llms:generate": {
			"outputLogs": "new-only"
		},
		"lint": {
			"outputLogs": "new-only"
		},
		"lint:check": {
			"outputLogs": "new-only"
		}
	}
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contractspec.dev/schemas/connect/plan-packet.schema.json",
  "title": "PlanPacket",
  "type": "object",
  "required": [
    "id",
    "taskId",
    "repoId",
    "branch",
    "actor",
    "objective",
    "steps",
    "impactedContracts",
    "affectedSurfaces",
    "requiredChecks",
    "requiredApprovals",
    "riskScore",
    "verificationStatus",
    "controlPlane"
  ],
  "properties": {
    "id": { "type": "string" },
    "taskId": { "type": "string" },
    "repoId": { "type": "string" },
    "branch": { "type": "string" },
    "actor": { "$ref": "#/$defs/actor" },
    "objective": { "type": "string" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "summary"],
        "properties": {
          "id": { "type": "string" },
          "summary": { "type": "string" },
          "paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "contractRefs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "impactedContracts": {
      "type": "array",
      "items": { "$ref": "#/$defs/contractRef" }
    },
    "affectedSurfaces": {
      "type": "array",
      "items": {
        "enum": ["agent", "audit", "cli", "contract", "harness", "knowledge", "mcp", "runtime"]
      }
    },
    "requiredChecks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredApprovals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["capability", "reason"],
        "properties": {
          "capability": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "riskScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "verificationStatus": {
      "enum": ["approved", "revise", "review", "denied"]
    },
  "controlPlane": {
    "type": "object",
    "required": ["intentSubmit", "planCompile", "planVerify"],
    "properties": {
      "intentSubmit": { "$ref": "#/$defs/contractRef" },
      "planCompile": { "$ref": "#/$defs/contractRef" },
      "planVerify": { "$ref": "#/$defs/contractRef" },
      "decisionId": { "type": "string" },
      "traceId": { "type": "string" }
    }
  },
    "acpActions": {
      "type": "array",
      "items": {
        "enum": ["acp.fs.access", "acp.terminal.exec", "acp.tool.calls"]
      }
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["human", "agent", "service", "tool"] },
        "sessionId": { "type": "string" },
        "traceId": { "type": "string" }
      }
    },
    "contractRef": {
      "type": "object",
      "required": ["key", "version"],
      "properties": {
        "key": { "type": "string" },
        "version": { "type": "string" },
        "kind": { "enum": ["command", "query", "event", "policy", "capability"] }
      }
    }
  }
}

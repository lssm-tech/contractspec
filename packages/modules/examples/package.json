{
	"name": "@contractspec/module.examples",
	"version": "4.0.10",
	"description": "Example contract specifications collection",
	"keywords": [
		"contractspec",
		"examples",
		"starter",
		"templates",
		"typescript"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"test": "bun test",
		"generate:registry": "bun ../../../scripts/generate-example-registry.ts --write",
		"prebuild": "bun run generate:registry && contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@apollo/client": "catalog:graphql",
		"@contractspec/example.agent-console": "workspace:*",
		"@contractspec/example.ai-chat-assistant": "workspace:*",
		"@contractspec/example.analytics-dashboard": "workspace:*",
		"@contractspec/example.crm-pipeline": "workspace:*",
		"@contractspec/example.data-grid-showcase": "workspace:*",
		"@contractspec/example.finance-ops-ai-workflows": "workspace:*",
		"@contractspec/example.form-showcase": "workspace:*",
		"@contractspec/example.in-app-docs": "workspace:*",
		"@contractspec/example.integration-hub": "workspace:*",
		"@contractspec/example.learning-journey-registry": "workspace:*",
		"@contractspec/example.marketplace": "workspace:*",
		"@contractspec/example.pocket-family-office": "workspace:*",
		"@contractspec/example.policy-safe-knowledge-assistant": "workspace:*",
		"@contractspec/example.saas-boilerplate": "workspace:*",
		"@contractspec/example.visualization-showcase": "workspace:*",
		"@contractspec/example.wealth-snapshot": "workspace:*",
		"@contractspec/example.workflow-system": "workspace:*",
		"@contractspec/lib.contracts-runtime-client-react": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.example-shared-ui": "workspace:*",
		"@contractspec/lib.presentation-runtime-core": "workspace:*",
		"@contractspec/lib.runtime-sandbox": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"exports": {
		".": "./src/index.ts",
		"./catalog": "./src/catalog.ts",
		"./runtime": "./src/runtime/index.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./catalog": {
				"types": "./dist/catalog.d.ts",
				"bun": "./dist/catalog.js",
				"node": "./dist/node/catalog.js",
				"default": "./dist/catalog.js"
			},
			"./runtime": {
				"types": "./dist/runtime/index.d.ts",
				"bun": "./dist/runtime/index.js",
				"node": "./dist/node/runtime/index.js",
				"default": "./dist/runtime/index.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/modules/examples"
	},
	"homepage": "https://contractspec.io"
}

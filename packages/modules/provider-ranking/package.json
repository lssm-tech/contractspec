{
  "name": "@contractspec/module.provider-ranking",
  "version": "0.4.0",
  "description": "AI provider ranking module with persistence and pipeline orchestration",
  "keywords": [
    "contractspec",
    "ai",
    "ranking",
    "benchmark",
    "module"
  ],
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
    "publish:pkg:canary": "bun publish:pkg --tag canary",
    "build": "bun run prebuild && bun run build:bundle && bun run build:types",
    "build:bundle": "contractspec-bun-build transpile",
    "build:types": "contractspec-bun-build types",
    "dev": "contractspec-bun-build dev",
    "clean": "rimraf dist .turbo",
    "lint": "bun lint:fix",
    "lint:fix": "eslint src --fix",
    "lint:check": "eslint src",
    "prebuild": "contractspec-bun-build prebuild",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contractspec/lib.provider-ranking": "workspace:*",
    "@contractspec/lib.schema": "workspace:*",
    "@contractspec/lib.contracts-integrations": "workspace:*"
  },
  "devDependencies": {
    "@contractspec/tool.typescript": "workspace:*",
    "@contractspec/tool.bun": "workspace:*",
    "typescript": "catalog:"
  },
  "exports": {
    ".": "./src/index.ts",
    "./entities": "./src/entities/index.ts",
    "./entities/index": "./src/entities/index.ts",
    "./pipeline": "./src/pipeline/index.ts",
    "./pipeline/index": "./src/pipeline/index.ts",
    "./pipeline/ingestion-pipeline": "./src/pipeline/ingestion-pipeline.ts",
    "./pipeline/ranking-pipeline": "./src/pipeline/ranking-pipeline.ts",
    "./storage": "./src/storage/index.ts",
    "./storage/index": "./src/storage/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "bun": "./dist/index.js",
        "node": "./dist/node/index.js",
        "browser": "./dist/browser/index.js",
        "default": "./dist/index.js"
      },
      "./entities": {
        "types": "./dist/entities/index.d.ts",
        "bun": "./dist/entities/index.js",
        "node": "./dist/node/entities/index.js",
        "browser": "./dist/browser/entities/index.js",
        "default": "./dist/entities/index.js"
      },
      "./entities/index": {
        "types": "./dist/entities/index.d.ts",
        "bun": "./dist/entities/index.js",
        "node": "./dist/node/entities/index.js",
        "browser": "./dist/browser/entities/index.js",
        "default": "./dist/entities/index.js"
      },
      "./pipeline": {
        "types": "./dist/pipeline/index.d.ts",
        "bun": "./dist/pipeline/index.js",
        "node": "./dist/node/pipeline/index.js",
        "browser": "./dist/browser/pipeline/index.js",
        "default": "./dist/pipeline/index.js"
      },
      "./pipeline/index": {
        "types": "./dist/pipeline/index.d.ts",
        "bun": "./dist/pipeline/index.js",
        "node": "./dist/node/pipeline/index.js",
        "browser": "./dist/browser/pipeline/index.js",
        "default": "./dist/pipeline/index.js"
      },
      "./pipeline/ingestion-pipeline": {
        "types": "./dist/pipeline/ingestion-pipeline.d.ts",

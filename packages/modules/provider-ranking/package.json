        "bun": "./dist/storage/index.js",
        "node": "./dist/node/storage/index.js",
        "browser": "./dist/browser/storage/index.js",
        "default": "./dist/storage/index.js"
      },
      "./storage/index": {
        "types": "./dist/storage/index.d.ts",
        "bun": "./dist/storage/index.js",
        "node": "./dist/node/storage/index.js",
        "browser": "./dist/browser/storage/index.js",
        "default": "./dist/storage/index.js"
      }

{
	"extends": "@contractspec/tool.typescript/react-library.json",
	"include": ["src"],
	"exclude": ["node_modules", "dist"],
	"compilerOptions": {
		"baseUrl": ".",
		"outDir": "dist",
		"paths": {
			"@contractspec/lib.builder-spec": [
				"../../libs/builder-spec/dist/index.d.ts"
			],
			"@contractspec/lib.builder-spec/*": ["../../libs/builder-spec/dist/*"],

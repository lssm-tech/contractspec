{
	"name": "@contractspec/module.notifications",
	"version": "3.7.19",
	"description": "Notification center module for ContractSpec applications",
	"keywords": [
		"contractspec",
		"notifications",
		"messaging",
		"channels",
		"email",
		"typescript"
	],
	"types": "./dist/index.d.ts",
	"type": "module",
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"test": "bun test",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/lib.schema": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.bus": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"exports": {
		".": "./src/index.ts",
		"./channels": "./src/channels/index.ts",
		"./contracts": "./src/contracts/index.ts",
		"./entities": "./src/entities/index.ts",
		"./i18n": "./src/i18n/index.ts",
		"./i18n/catalogs": "./src/i18n/catalogs/index.ts",
		"./i18n/catalogs/en": "./src/i18n/catalogs/en.ts",
		"./i18n/catalogs/es": "./src/i18n/catalogs/es.ts",
		"./i18n/catalogs/fr": "./src/i18n/catalogs/fr.ts",
		"./i18n/keys": "./src/i18n/keys.ts",
		"./i18n/locale": "./src/i18n/locale.ts",
		"./i18n/messages": "./src/i18n/messages.ts",
		"./notifications.capability": "./src/notifications.capability.ts",
		"./notifications.feature": "./src/notifications.feature.ts",
		"./templates": "./src/templates/index.ts"
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./channels": {
				"types": "./dist/channels/index.d.ts",
				"browser": "./dist/browser/channels/index.js",
				"bun": "./dist/channels/index.js",
				"node": "./dist/node/channels/index.js",

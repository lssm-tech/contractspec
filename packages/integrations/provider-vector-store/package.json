{
	"name": "@contractspec/integration.provider.vector-store",
	"version": "0.2.3",
	"description": "Vector store provider implementations for ContractSpec.",
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"test": "bun test",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/integrations/provider-vector-store"
	},
	"dependencies": {
		"@contractspec/integration.provider.database": "workspace:*",
		"@contractspec/integration.runtime": "workspace:*",
		"@contractspec/lib.contracts-integrations": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.bun": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"@qdrant/js-client-rest": "^1.17.0",
		"@types/bun": "catalog:types",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./impls": "./src/impls/index.ts",
		"./impls/qdrant-vector": "./src/impls/qdrant-vector.ts",
		"./impls/supabase-vector": "./src/impls/supabase-vector.ts",
		"./vector-store": "./src/vector-store.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./impls": {
				"types": "./dist/impls/index.d.ts",
				"browser": "./dist/browser/impls/index.js",
				"bun": "./dist/impls/index.js",
				"node": "./dist/node/impls/index.js",
				"default": "./dist/impls/index.js"
			},
			"./impls/qdrant-vector": {
				"types": "./dist/impls/qdrant-vector.d.ts",
				"browser": "./dist/browser/impls/qdrant-vector.js",
				"bun": "./dist/impls/qdrant-vector.js",
				"node": "./dist/node/impls/qdrant-vector.js",
				"default": "./dist/impls/qdrant-vector.js"
			},
			"./impls/supabase-vector": {
				"types": "./dist/impls/supabase-vector.d.ts",
				"browser": "./dist/browser/impls/supabase-vector.js",
				"bun": "./dist/impls/supabase-vector.js",
				"node": "./dist/node/impls/supabase-vector.js",
				"default": "./dist/impls/supabase-vector.js"
			},
			"./vector-store": {
				"types": "./dist/vector-store.d.ts",
				"browser": "./dist/browser/vector-store.js",
				"bun": "./dist/vector-store.js",
				"node": "./dist/node/vector-store.js",
				"default": "./dist/vector-store.js"
			}
		}
	}
}

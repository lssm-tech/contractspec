{
	"name": "@contractspec/integration.provider.copilot",
	"version": "0.2.5",
	"description": "Copilot provider compatibility wrapper for Builder.",
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"test": "bun test",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/integrations/provider-copilot"
	},
	"dependencies": {
		"@contractspec/lib.provider-spec": "workspace:*",
		"@contractspec/lib.contracts-integrations": "workspace:*",
		"@contractspec/lib.schema": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.bun": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./integration": "./src/integration.ts"
	},
	"publishConfig": {
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./integration": {
				"types": "./dist/integration.d.ts",
				"browser": "./dist/browser/integration.js",
				"bun": "./dist/integration.js",
				"node": "./dist/node/integration.js",
				"default": "./dist/integration.js"
			}
		}
	}
}

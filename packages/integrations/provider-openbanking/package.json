{
	"name": "@contractspec/integration.provider.openbanking",
	"version": "0.2.2",
	"description": "Open banking provider implementations for ContractSpec.",
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"test": "bun test",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/integrations/provider-openbanking"
	},
	"dependencies": {
		"@contractspec/integration.runtime": "workspace:*",
		"@contractspec/lib.contracts-integrations": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.bun": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"@types/bun": "catalog:types",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./impls": "./src/impls/index.ts",
		"./impls/powens-client": "./src/impls/powens-client.ts",
		"./impls/powens-openbanking": "./src/impls/powens-openbanking.ts",
		"./openbanking": "./src/openbanking.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./impls": {
				"types": "./dist/impls/index.d.ts",
				"bun": "./dist/impls/index.js",
				"node": "./dist/node/impls/index.js",
				"default": "./dist/impls/index.js"
			},
			"./impls/powens-client": {
				"types": "./dist/impls/powens-client.d.ts",
				"bun": "./dist/impls/powens-client.js",
				"node": "./dist/node/impls/powens-client.js",
				"default": "./dist/impls/powens-client.js"
			},
			"./impls/powens-openbanking": {
				"types": "./dist/impls/powens-openbanking.d.ts",
				"bun": "./dist/impls/powens-openbanking.js",
				"node": "./dist/node/impls/powens-openbanking.js",
				"default": "./dist/impls/powens-openbanking.js"
			},
			"./openbanking": {
				"types": "./dist/openbanking.d.ts",
				"bun": "./dist/openbanking.js",
				"node": "./dist/node/openbanking.js",
				"default": "./dist/openbanking.js"
			}
		}
	}
}

{
	"name": "@contractspec/biome-config",
	"version": "3.7.6",
	"type": "module",
	"description": "Biome presets, Grit plugins, and policy manifest for ContractSpec repositories.",
	"keywords": [
		"biome",
		"contractspec",
		"grit",
		"lint",
		"policy"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run prebuild && bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"clean": "rimraf dist .turbo",
		"lint": "bun run lint:fix",
		"lint:fix": "biome check --write --unsafe --only=nursery/useSortedClasses . && biome check --write .",
		"lint:check": "biome check .",
		"sync:artifacts": "bun src/sync.ts",
		"test": "bun test",
		"prebuild": "bun run sync:artifacts && contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit",
		"dev": "contractspec-bun-build dev"
	},
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"dist",
		"README.md",
		"presets",
		"plugins",
		"ai"
	],
	"devDependencies": {
		"@contractspec/tool.bun": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			}
		}
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/tools/biome-config"
	},
	"homepage": "https://contractspec.io",
	"types": "./dist/index.d.ts"
}

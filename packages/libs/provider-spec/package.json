{
	"name": "@contractspec/lib.provider-spec",
	"version": "0.2.5",
	"description": "Provider routing and runtime-target contracts for ContractSpec Builder.",
	"keywords": [
		"contractspec",
		"builder",
		"providers",
		"runtime",
		"typescript"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"test": "bun test",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.bun": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./types": "./src/types.ts",
		"./validation": "./src/validation.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./types": {
				"types": "./dist/types.d.ts",
				"browser": "./dist/browser/types.js",
				"bun": "./dist/types.js",
				"node": "./dist/node/types.js",
				"default": "./dist/types.js"
			},
			"./validation": {
				"types": "./dist/validation.d.ts",
				"browser": "./dist/browser/validation.js",
				"bun": "./dist/validation.js",
				"node": "./dist/node/validation.js",
				"default": "./dist/validation.js"
			}
		}
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/provider-spec"
	},
	"homepage": "https://contractspec.io"
}

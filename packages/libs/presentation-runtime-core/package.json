{
	"name": "@contractspec/lib.presentation-runtime-core",
	"version": "5.2.3",
	"description": "Core presentation runtime for contract-driven UIs",
	"keywords": [
		"contractspec",
		"presentation",
		"runtime",
		"ui",
		"core",
		"typescript"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:require && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:require": "bun build src/metro.ts --target node --format cjs --packages external --outfile dist/metro.cjs",
		"build:types": "contractspec-bun-build types",
		"clean": "rimraf dist .turbo",
		"dev": "contractspec-bun-build dev",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"peerDependencies": {
		"typescript": "^5.9.0"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*",
		"echarts": "catalog:ui",
		"turndown": "^7.2.4"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*",
		"@types/turndown": "^5.0.6"
	},
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"require": "./src/metro.ts",
			"default": "./src/index.ts"
		},
		"./metro": {
			"types": "./src/metro.ts",
			"require": "./src/metro.ts",
			"default": "./src/metro.ts"
		},
		"./next": "./src/next.ts",
		"./presentation-aliases": "./src/presentation-aliases.ts",
		"./presentation-runtime-core.feature": "./src/presentation-runtime-core.feature.ts",
		"./table": "./src/table.ts",
		"./transform-engine": "./src/transform-engine.ts",
		"./transform-engine.markdown": "./src/transform-engine.markdown.ts",
		"./visualization": "./src/visualization.ts",
		"./visualization.echarts": "./src/visualization.echarts.ts",
		"./visualization.model": "./src/visualization.model.ts",
		"./visualization.model.builders": "./src/visualization.model.builders.ts",
		"./visualization.model.helpers": "./src/visualization.model.helpers.ts",
		"./visualization.types": "./src/visualization.types.ts",
		"./visualization.utils": "./src/visualization.utils.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"require": "./dist/metro.cjs",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./metro": {
				"types": "./dist/metro.d.ts",
				"require": "./dist/metro.cjs",
				"browser": "./dist/browser/metro.js",
				"bun": "./dist/metro.js",
				"node": "./dist/node/metro.js",
				"default": "./dist/metro.js"
			},
			"./next": {
				"types": "./dist/next.d.ts",
				"browser": "./dist/browser/next.js",
				"bun": "./dist/next.js",
				"node": "./dist/node/next.js",
				"default": "./dist/next.js"
			},
			"./presentation-aliases": {
				"types": "./dist/presentation-aliases.d.ts",

				"browser": "./dist/browser/presentation-runtime-core.feature.js",
				"bun": "./dist/presentation-runtime-core.feature.js",
				"node": "./dist/node/presentation-runtime-core.feature.js",
				"default": "./dist/presentation-runtime-core.feature.js"
			},
			"./table": {
				"types": "./dist/table.d.ts",
				"browser": "./dist/browser/table.js",
				"bun": "./dist/table.js",
				"node": "./dist/node/table.js",
				"default": "./dist/table.js"
			},
			"./transform-engine": {
				"types": "./dist/transform-engine.d.ts",
				"browser": "./dist/browser/transform-engine.js",

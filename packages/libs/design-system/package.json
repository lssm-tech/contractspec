{
	"name": "@contractspec/lib.design-system",
	"version": "3.11.2",
	"description": "Design tokens and theming primitives",
	"keywords": [
		"contractspec",
		"design-system",
		"tokens",
		"theming",
		"ui",
		"typescript"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"registry:build": "bun run scripts/build-registry.ts",
		"test": "bun test --pass-with-no-tests",
		"test:build-artifacts": "node scripts/check-generated-js.mjs",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit -p tsconfig.build.json"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"tree-shake": true,
	"dependencies": {
		"@contractspec/lib.ai-agent": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.contracts-runtime-client-react": "workspace:*",
		"@contractspec/lib.presentation-runtime-react": "workspace:*",
		"@contractspec/lib.ui-kit": "workspace:*",
		"@contractspec/lib.ui-kit-web": "workspace:*",
		"@hookform/resolvers": "5.2.2",
		"class-variance-authority": "catalog:ui",
		"clsx": "catalog:ui",
		"lucide-react": "catalog:ui",
		"next": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-hook-form": "^7.72.1",
		"shiki": "^4.0.2",
		"tailwind-merge": "catalog:ui",
		"tailwindcss-animate": "catalog:ui",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"@types/node": "catalog:types",
		"@types/react-dom": "^19.0.14",
		"postcss": "catalog:build",
		"postcss-load-config": "^6.0.1",
		"react-native": "catalog:native",
		"react-native-css": "catalog:native",
		"tailwindcss": "catalog:build",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": "./src/index.ts",
		"./controls": "./src/components/forms/controls/index.ts",
		"./forms": "./src/components/forms/index.ts",
		"./layout": "./src/components/layout/index.ts",
		"./theme": "./src/theme/index.ts",
		"./renderers": "./src/renderers/index.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"default": "./dist/index.js"
			},
			"./controls": {
				"types": "./dist/components/forms/controls/index.d.ts",
				"browser": "./dist/browser/components/forms/controls/index.js",
				"bun": "./dist/components/forms/controls/index.js",
				"default": "./dist/components/forms/controls/index.js"
			},
			"./forms": {
				"types": "./dist/components/forms/index.d.ts",
				"browser": "./dist/browser/components/forms/index.js",
				"bun": "./dist/components/forms/index.js",
				"default": "./dist/components/forms/index.js"
			},
			"./layout": {
				"types": "./dist/components/layout/index.d.ts",
				"browser": "./dist/browser/components/layout/index.js",
				"bun": "./dist/components/layout/index.js",
				"default": "./dist/components/layout/index.js"
			},
			"./renderers": {
				"types": "./dist/renderers/index.d.ts",
				"browser": "./dist/browser/renderers/index.js",
				"bun": "./dist/renderers/index.js",
				"default": "./dist/renderers/index.js"
			},
			"./theme": {
				"types": "./dist/theme/index.d.ts",
				"browser": "./dist/browser/theme/index.js",
				"bun": "./dist/theme/index.js",
				"default": "./dist/theme/index.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/design-system"
	},
	"homepage": "https://contractspec.io"
}

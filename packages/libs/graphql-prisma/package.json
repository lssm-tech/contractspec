{
	"name": "@contractspec/lib.graphql-prisma",
	"version": "3.7.23",
	"description": "Pothos + Prisma builder factory with injectable client/DMMF",
	"keywords": [
		"contractspec",
		"graphql",
		"prisma",
		"pothos",
		"orm",
		"typescript"
	],
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"dev": "contractspec-bun-build dev",
		"clean": "rm -rf dist",
		"prebuild": "contractspec-bun-build prebuild",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/lib.schema": "workspace:*",
		"@pothos/core": "catalog:graphql",
		"@pothos/plugin-complexity": "catalog:graphql",
		"@pothos/plugin-dataloader": "catalog:graphql",
		"@pothos/plugin-prisma": "^4.14.3",
		"@pothos/plugin-relay": "catalog:graphql",
		"@pothos/plugin-tracing": "catalog:graphql",
		"graphql": "catalog:graphql",
		"graphql-scalars": "^1.22.5",
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"peerDependencies": {
		"graphql": ">=16.13.2"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./graphql-prisma.feature": "./src/graphql-prisma.feature.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./graphql-prisma.feature": {
				"types": "./dist/graphql-prisma.feature.d.ts",
				"browser": "./dist/browser/graphql-prisma.feature.js",
				"bun": "./dist/graphql-prisma.feature.js",
				"node": "./dist/node/graphql-prisma.feature.js",
				"default": "./dist/graphql-prisma.feature.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/graphql-prisma"
	},
	"homepage": "https://contractspec.io"
}

{
	"name": "@contractspec/lib.provider-runtime",
	"version": "0.2.2",
	"description": "Builder provider-runtime helpers for routing, context prep, runtime targets, and receipt normalization.",
	"keywords": [
		"contractspec",
		"builder",
		"provider",
		"runtime",
		"typescript"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"test": "bun test",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/lib.builder-spec": "workspace:*",
		"@contractspec/lib.mobile-control": "workspace:*",
		"@contractspec/lib.provider-spec": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.bun": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:"
	},
	"exports": {
		".": "./src/index.ts",
		"./comparison-run": "./src/comparison-run.ts",
		"./execution-context": "./src/execution-context.ts",
		"./execution-output": "./src/execution-output.ts",
		"./managed-builder-bootstrap": "./src/managed-builder-bootstrap.ts",
		"./managed-builder-bootstrap.resources": "./src/managed-builder-bootstrap.resources.ts",
		"./managed-builder-runtime-targets": "./src/managed-builder-runtime-targets.ts",
		"./providers": "./src/providers.ts",
		"./recommended-builder-setup": "./src/recommended-builder-setup.ts",
		"./routing-policy": "./src/routing-policy.ts",
		"./runtime-targets": "./src/runtime-targets.ts",
		"./shared": "./src/shared.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./comparison-run": {
				"types": "./dist/comparison-run.d.ts",
				"bun": "./dist/comparison-run.js",
				"node": "./dist/node/comparison-run.js",
				"default": "./dist/comparison-run.js"
			},
			"./execution-context": {
				"types": "./dist/execution-context.d.ts",
				"bun": "./dist/execution-context.js",
				"node": "./dist/node/execution-context.js",
				"default": "./dist/execution-context.js"
			},
			"./execution-output": {
				"types": "./dist/execution-output.d.ts",
				"bun": "./dist/execution-output.js",
				"node": "./dist/node/execution-output.js",
				"default": "./dist/execution-output.js"
			},
			"./managed-builder-bootstrap": {
				"types": "./dist/managed-builder-bootstrap.d.ts",
				"bun": "./dist/managed-builder-bootstrap.js",
				"node": "./dist/node/managed-builder-bootstrap.js",
				"default": "./dist/managed-builder-bootstrap.js"
			},
			"./managed-builder-bootstrap.resources": {
				"types": "./dist/managed-builder-bootstrap.resources.d.ts",
				"bun": "./dist/managed-builder-bootstrap.resources.js",
				"node": "./dist/node/managed-builder-bootstrap.resources.js",
				"default": "./dist/managed-builder-bootstrap.resources.js"
			},
			"./managed-builder-runtime-targets": {
				"types": "./dist/managed-builder-runtime-targets.d.ts",
				"bun": "./dist/managed-builder-runtime-targets.js",
				"node": "./dist/node/managed-builder-runtime-targets.js",
				"default": "./dist/managed-builder-runtime-targets.js"
			},
			"./providers": {
				"types": "./dist/providers.d.ts",
				"bun": "./dist/providers.js",
				"node": "./dist/node/providers.js",
				"default": "./dist/providers.js"
			},
			"./recommended-builder-setup": {
				"types": "./dist/recommended-builder-setup.d.ts",
				"bun": "./dist/recommended-builder-setup.js",
				"node": "./dist/node/recommended-builder-setup.js",
				"default": "./dist/recommended-builder-setup.js"
			},
			"./routing-policy": {
				"types": "./dist/routing-policy.d.ts",
				"bun": "./dist/routing-policy.js",
				"node": "./dist/node/routing-policy.js",
				"default": "./dist/routing-policy.js"
			},
			"./runtime-targets": {
				"types": "./dist/runtime-targets.d.ts",
				"bun": "./dist/runtime-targets.js",
				"node": "./dist/node/runtime-targets.js",
				"default": "./dist/runtime-targets.js"
			},
			"./shared": {
				"types": "./dist/shared.d.ts",
				"bun": "./dist/shared.js",
				"node": "./dist/node/shared.js",
				"default": "./dist/shared.js"
			}
		}
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/provider-runtime"
	},
	"homepage": "https://contractspec.io"
}

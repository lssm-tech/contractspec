{
	"name": "@contractspec/lib.plugins",
	"version": "3.7.8",
	"description": "Plugin API and registry for ContractSpec extensions",
	"keywords": [
		"contractspec",
		"plugins",
		"extensions",
		"generator",
		"validator",
		"adapter",
		"registry",
		"typescript"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run prebuild && bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "biome check --write --unsafe --only=nursery/useSortedClasses . && biome check --write .",
		"lint:check": "biome check .",
		"test": "bun test --pass-with-no-tests",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.schema": "workspace:*",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"exports": {
		".": "./src/index.ts",
		"./config": "./src/config.ts",
		"./registry": "./src/registry.ts",
		"./types": "./src/types.ts"
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./config": {
				"types": "./dist/config.d.ts",
				"browser": "./dist/browser/config.js",
				"bun": "./dist/config.js",
				"node": "./dist/node/config.js",
				"default": "./dist/config.js"
			},
			"./registry": {
				"types": "./dist/registry.d.ts",
				"browser": "./dist/browser/registry.js",
				"bun": "./dist/registry.js",
				"node": "./dist/node/registry.js",
				"default": "./dist/registry.js"
			},
			"./types": {
				"types": "./dist/types.d.ts",
				"browser": "./dist/browser/types.js",
				"bun": "./dist/types.js",
				"node": "./dist/node/types.js",
				"default": "./dist/types.js"
			}
		}
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/plugins"
	},
	"homepage": "https://contractspec.io"
}

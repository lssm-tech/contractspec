{
	"extends": "@contractspec/tool.typescript/react-library.json",
	"include": ["src"],
	"exclude": ["node_modules"],
	"compilerOptions": {
		"outDir": "dist",
		"paths": {
			"@contractspec/lib.contracts-spec": ["../contracts-spec/src/index.ts"],
			"@contractspec/lib.contracts-spec/*": ["../contracts-spec/src/*"],
			"@contractspec/lib.schema": ["../schema/src/index.ts"],
			"@contractspec/lib.schema/*": ["../schema/src/*"]
		}
	}
}

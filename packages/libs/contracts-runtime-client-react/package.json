{
	"name": "@contractspec/lib.contracts-runtime-client-react",
	"version": "3.13.0",
	"description": "React runtime adapters for ContractSpec contracts",
	"type": "module",
	"types": "./dist/index.d.ts",
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"clean": "rm -rf dist",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit",
		"dev": "contractspec-bun-build dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/contract-runtime-client-react"
	},
	"peerDependencies": {
		"@hookform/resolvers": "catalog:ui",
		"react": "catalog:",
		"react-dom": "catalog:",
		"react-hook-form": "catalog:ui"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.schema": "workspace:*",
		"@contractspec/lib.presentation-runtime-core": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": "./src/index.ts",
		"./contract-result-client": "./src/contract-result-client.tsx",
		"./contracts-runtime-client-react.feature": "./src/contracts-runtime-client-react.feature.ts",
		"./drivers/rn-reusables": "./src/drivers/rn-reusables.ts",
		"./drivers/shadcn": "./src/drivers/shadcn.ts",
		"./feature-render": "./src/feature-render.ts",
		"./form-render": "./src/form-render.ts",
		"./form-render.impl": "./src/form-render.impl.tsx",
		"./transform-engine": "./src/transform-engine.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./contract-result-client": {
				"types": "./dist/contract-result-client.d.ts",
				"browser": "./dist/browser/contract-result-client.js",
				"bun": "./dist/contract-result-client.js",
				"node": "./dist/node/contract-result-client.js",
				"default": "./dist/contract-result-client.js"
			},
			"./contracts-runtime-client-react.feature": {
				"types": "./dist/contracts-runtime-client-react.feature.d.ts",
				"browser": "./dist/browser/contracts-runtime-client-react.feature.js",
				"bun": "./dist/contracts-runtime-client-react.feature.js",
				"node": "./dist/node/contracts-runtime-client-react.feature.js",
				"default": "./dist/contracts-runtime-client-react.feature.js"
			},
			"./drivers/rn-reusables": {
				"types": "./dist/drivers/rn-reusables.d.ts",
				"browser": "./dist/browser/drivers/rn-reusables.js",
				"bun": "./dist/drivers/rn-reusables.js",
				"node": "./dist/node/drivers/rn-reusables.js",
				"default": "./dist/drivers/rn-reusables.js"
			},
			"./drivers/shadcn": {
				"types": "./dist/drivers/shadcn.d.ts",
				"browser": "./dist/browser/drivers/shadcn.js",
				"bun": "./dist/drivers/shadcn.js",
				"node": "./dist/node/drivers/shadcn.js",
				"default": "./dist/drivers/shadcn.js"
			},
			"./feature-render": {
				"types": "./dist/feature-render.d.ts",
				"browser": "./dist/browser/feature-render.js",
				"bun": "./dist/feature-render.js",
				"node": "./dist/node/feature-render.js",
				"default": "./dist/feature-render.js"
			},
			"./form-render": {
				"types": "./dist/form-render.d.ts",
				"browser": "./dist/browser/form-render.js",
				"bun": "./dist/form-render.js",
				"node": "./dist/node/form-render.js",
				"default": "./dist/form-render.js"
			},
			"./form-render.impl": {
				"types": "./dist/form-render.impl.d.ts",
				"browser": "./dist/browser/form-render.impl.js",
				"bun": "./dist/form-render.impl.js",
				"node": "./dist/node/form-render.impl.js",
				"default": "./dist/form-render.impl.js"
			},
			"./transform-engine": {
				"types": "./dist/transform-engine.d.ts",
				"browser": "./dist/browser/transform-engine.js",
				"bun": "./dist/transform-engine.js",
				"node": "./dist/node/transform-engine.js",
				"default": "./dist/transform-engine.js"
			}
		}
	}
}

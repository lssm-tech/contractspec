{
	"name": "@contractspec/lib.presentation-runtime-react-native",
	"version": "38.0.2",
	"description": "React Native presentation runtime for mobile apps",
	"keywords": [
		"contractspec",
		"presentation",
		"react-native",
		"mobile",
		"ui",
		"typescript"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"scripts": {
		"clean": "rimraf dist .turbo",
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"peerDependencies": {
		"react": "catalog:",
		"react-native": "*",
		"react-hook-form": "catalog:ui",
		"zod": "catalog:",
		"@contractspec/lib.presentation-runtime-core": "workspace:*"
	},
	"dependencies": {
		"@tanstack/react-table": "^8.21.3",
		"@contractspec/lib.presentation-runtime-react": "workspace:*",
		"@contractspec/lib.presentation-runtime-core": "workspace:*",
		"@contractspec/lib.ui-kit": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": "./src/index.ts",
		"./nativewind-env.d": "./src/nativewind-env.d.ts",
		"./presentation-runtime-react-native.feature": "./src/presentation-runtime-react-native.feature.ts",
		"./useContractTable": "./src/useContractTable.ts",
		"./useDataViewTable": "./src/useDataViewTable.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"default": "./dist/index.js"
			},
			"./nativewind-env.d": {
				"types": "./dist/nativewind-env.d.d.ts",
				"browser": "./dist/browser/nativewind-env.d.js",
				"bun": "./dist/nativewind-env.d.js",
				"default": "./dist/nativewind-env.d.js"
			},
			"./presentation-runtime-react-native.feature": {
				"types": "./dist/presentation-runtime-react-native.feature.d.ts",
				"browser": "./dist/browser/presentation-runtime-react-native.feature.js",
				"bun": "./dist/presentation-runtime-react-native.feature.js",
				"default": "./dist/presentation-runtime-react-native.feature.js"
			},
			"./useContractTable": {
				"types": "./dist/useContractTable.d.ts",
				"browser": "./dist/browser/useContractTable.js",
				"bun": "./dist/useContractTable.js",
				"default": "./dist/useContractTable.js"
			},
			"./useDataViewTable": {
				"types": "./dist/useDataViewTable.d.ts",
				"browser": "./dist/browser/useDataViewTable.js",
				"bun": "./dist/useDataViewTable.js",
				"default": "./dist/useDataViewTable.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/presentation-runtime-react-native"
	},
	"homepage": "https://contractspec.io",
	"devDependencies": {
		"react-native-css": "catalog:native",
		"@contractspec/tool.bun": "workspace:*"
	}
}

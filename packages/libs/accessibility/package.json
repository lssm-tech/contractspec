{
	"name": "@contractspec/lib.accessibility",
	"version": "3.7.25",
	"description": "WCAG compliance utilities and validators",
	"keywords": [
		"contractspec",
		"accessibility",
		"a11y",
		"wcag",
		"react",
		"typescript"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/lib.design-system": "workspace:*",
		"@contractspec/lib.ui-kit": "workspace:*",
		"@contractspec/lib.ui-kit-web": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"react-native-css": "catalog:native",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"peerDependencies": {
		"react": "catalog:",
		"next": "catalog:"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"sideEffects": [
		"./dist/index.js",
		"./dist/*.css"
	],
	"exports": {
		".": "./src/index.ts",
		"./accessibility.feature": "./src/accessibility.feature.ts",
		"./AccessibilityPanel": "./src/AccessibilityPanel.tsx",
		"./AccessibilityProvider": "./src/AccessibilityProvider.tsx",
		"./nativewind-env.d": "./src/nativewind-env.d.ts",
		"./next-route-announcer": "./src/next-route-announcer.tsx",
		"./preferences": "./src/preferences.tsx",
		"./styles.css": {
			"style": "./src/styles.css",
			"default": "./src/styles.css"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"default": "./dist/index.js"
			},
			"./accessibility.feature": {
				"types": "./dist/accessibility.feature.d.ts",
				"browser": "./dist/browser/accessibility.feature.js",
				"bun": "./dist/accessibility.feature.js",
				"default": "./dist/accessibility.feature.js"
			},
			"./AccessibilityPanel": {
				"types": "./dist/AccessibilityPanel.d.ts",
				"browser": "./dist/browser/AccessibilityPanel.js",
				"bun": "./dist/AccessibilityPanel.js",
				"default": "./dist/AccessibilityPanel.js"
			},
			"./AccessibilityProvider": {
				"types": "./dist/AccessibilityProvider.d.ts",
				"browser": "./dist/browser/AccessibilityProvider.js",
				"bun": "./dist/AccessibilityProvider.js",
				"default": "./dist/AccessibilityProvider.js"
			},
			"./nativewind-env.d": {
				"types": "./dist/nativewind-env.d.d.ts",
				"browser": "./dist/browser/nativewind-env.d.js",
				"bun": "./dist/nativewind-env.d.js",
				"default": "./dist/nativewind-env.d.js"
			},
			"./next-route-announcer": {
				"types": "./dist/next-route-announcer.d.ts",
				"browser": "./dist/browser/next-route-announcer.js",
				"bun": "./dist/next-route-announcer.js",
				"default": "./dist/next-route-announcer.js"
			},
			"./preferences": {
				"types": "./dist/preferences.d.ts",
				"browser": "./dist/browser/preferences.js",
				"bun": "./dist/preferences.js",
				"default": "./dist/preferences.js"
			},
			"./styles.css": {
				"style": "./dist/styles.css",
				"default": "./dist/styles.css"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/accessibility"
	},
	"homepage": "https://contractspec.io"
}

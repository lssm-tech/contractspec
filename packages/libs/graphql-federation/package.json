{
	"name": "@contractspec/lib.graphql-federation",
	"version": "3.7.18",
	"description": "Pothos federation helpers and subgraph schema export utilities",
	"keywords": [
		"contractspec",
		"graphql",
		"federation",
		"apollo",
		"subgraph",
		"typescript"
	],
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"dev": "contractspec-bun-build dev",
		"clean": "rm -rf dist",
		"prebuild": "contractspec-bun-build prebuild",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@pothos/core": "catalog:graphql",
		"@pothos/plugin-federation": "^4.0.0",
		"@pothos/plugin-directives": "^4.2.3",
		"graphql": "catalog:graphql",
		"@apollo/subgraph": "^2.13.3",
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"peerDependencies": {
		"graphql": ">=16.13.2"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./graphql-federation.feature": "./src/graphql-federation.feature.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./graphql-federation.feature": {
				"types": "./dist/graphql-federation.feature.d.ts",
				"browser": "./dist/browser/graphql-federation.feature.js",
				"bun": "./dist/graphql-federation.feature.js",
				"node": "./dist/node/graphql-federation.feature.js",
				"default": "./dist/graphql-federation.feature.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/graphql-federation"
	},
	"homepage": "https://contractspec.io"
}

{
	"name": "@contractspec/lib.surface-runtime",
	"version": "0.5.17",
	"description": "AI-native surface specs and web runtime for adaptive ContractSpec surfaces",
	"keywords": [
		"contractspec",
		"surface",
		"runtime",
		"bundle",
		"ai-native",
		"personalization",
		"typescript"
	],
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],

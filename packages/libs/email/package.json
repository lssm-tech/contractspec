{
	"name": "@contractspec/lib.email",
	"version": "3.7.16",
	"type": "module",
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"clean": "rm -rf dist",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit",
		"dev": "contractspec-bun-build dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/email"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./client": {
				"types": "./dist/client.d.ts",
				"browser": "./dist/browser/client.js",
				"bun": "./dist/client.js",
				"node": "./dist/node/client.js",
				"default": "./dist/client.js"
			},
			"./email.feature": {
				"types": "./dist/email.feature.d.ts",
				"browser": "./dist/browser/email.feature.js",
				"bun": "./dist/email.feature.js",
				"node": "./dist/node/email.feature.js",
				"default": "./dist/email.feature.js"
			},
			"./types": {
				"types": "./dist/types.d.ts",
				"browser": "./dist/browser/types.js",
				"bun": "./dist/types.js",
				"node": "./dist/node/types.js",
				"default": "./dist/types.js"
			},
			"./utils": {
				"types": "./dist/utils.d.ts",
				"browser": "./dist/browser/utils.js",
				"bun": "./dist/utils.js",
				"node": "./dist/node/utils.js",
				"default": "./dist/utils.js"
			}
		}
	},
	"exports": {
		".": "./src/index.ts",
		"./client": "./src/client.ts",
		"./email.feature": "./src/email.feature.ts",
		"./types": "./src/types.ts",
		"./utils": "./src/utils.ts"
	},
	"types": "./dist/index.d.ts",
	"dependencies": {
		"@scaleway/sdk": "catalog:integrations",
		"@scaleway/sdk-client": "catalog:integrations",
		"@contractspec/lib.logger": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	}
}

{
	"name": "@contractspec/lib.contracts-runtime-server-rest",
	"version": "3.8.1",
	"description": "REST server runtime adapters for ContractSpec contracts",
	"type": "module",
	"types": "./dist/index.d.ts",
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"clean": "rm -rf dist",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit",
		"dev": "contractspec-bun-build dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/contract-runtime-server-rest"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.schema": "workspace:*"
	},
	"peerDependencies": {
		"@pothos/core": "catalog:graphql",
		"elysia": "catalog:server",
		"express": "catalog:server",
		"next": "catalog:"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": "./src/index.ts",
		"./contracts-adapter-hydration": "./src/contracts-adapter-hydration.ts",
		"./contracts-adapter-input": "./src/contracts-adapter-input.ts",
		"./contracts-runtime-server-rest.feature": "./src/contracts-runtime-server-rest.feature.ts",
		"./rest-elysia": "./src/rest-elysia.ts",
		"./rest-express": "./src/rest-express.ts",
		"./rest-generic": "./src/rest-generic.ts",
		"./rest-nest": "./src/rest-nest.ts",
		"./rest-next-app": "./src/rest-next-app.ts",
		"./rest-next-pages": "./src/rest-next-pages.ts",
		"./result-response": "./src/result-response.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./contracts-adapter-hydration": {
				"types": "./dist/contracts-adapter-hydration.d.ts",
				"browser": "./dist/browser/contracts-adapter-hydration.js",
				"bun": "./dist/contracts-adapter-hydration.js",
				"node": "./dist/node/contracts-adapter-hydration.js",
				"default": "./dist/contracts-adapter-hydration.js"
			},
			"./contracts-adapter-input": {
				"types": "./dist/contracts-adapter-input.d.ts",
				"browser": "./dist/browser/contracts-adapter-input.js",
				"bun": "./dist/contracts-adapter-input.js",
				"node": "./dist/node/contracts-adapter-input.js",
				"default": "./dist/contracts-adapter-input.js"
			},
			"./contracts-runtime-server-rest.feature": {
				"types": "./dist/contracts-runtime-server-rest.feature.d.ts",
				"browser": "./dist/browser/contracts-runtime-server-rest.feature.js",
				"bun": "./dist/contracts-runtime-server-rest.feature.js",
				"node": "./dist/node/contracts-runtime-server-rest.feature.js",
				"default": "./dist/contracts-runtime-server-rest.feature.js"
			},
			"./rest-elysia": {
				"types": "./dist/rest-elysia.d.ts",
				"browser": "./dist/browser/rest-elysia.js",
				"bun": "./dist/rest-elysia.js",
				"node": "./dist/node/rest-elysia.js",
				"default": "./dist/rest-elysia.js"
			},
			"./rest-express": {
				"types": "./dist/rest-express.d.ts",
				"browser": "./dist/browser/rest-express.js",
				"bun": "./dist/rest-express.js",
				"node": "./dist/node/rest-express.js",
				"default": "./dist/rest-express.js"
			},
			"./rest-generic": {
				"types": "./dist/rest-generic.d.ts",
				"browser": "./dist/browser/rest-generic.js",
				"bun": "./dist/rest-generic.js",
				"node": "./dist/node/rest-generic.js",
				"default": "./dist/rest-generic.js"
			},
			"./rest-nest": {
				"types": "./dist/rest-nest.d.ts",
				"browser": "./dist/browser/rest-nest.js",
				"bun": "./dist/rest-nest.js",
				"node": "./dist/node/rest-nest.js",
				"default": "./dist/rest-nest.js"
			},
			"./rest-next-app": {
				"types": "./dist/rest-next-app.d.ts",
				"browser": "./dist/browser/rest-next-app.js",
				"bun": "./dist/rest-next-app.js",
				"node": "./dist/node/rest-next-app.js",
				"default": "./dist/rest-next-app.js"
			},
			"./rest-next-pages": {
				"types": "./dist/rest-next-pages.d.ts",
				"browser": "./dist/browser/rest-next-pages.js",
				"bun": "./dist/rest-next-pages.js",
				"node": "./dist/node/rest-next-pages.js",
				"default": "./dist/rest-next-pages.js"
			},
			"./result-response": {
				"types": "./dist/result-response.d.ts",
				"browser": "./dist/browser/result-response.js",
				"bun": "./dist/result-response.js",
				"node": "./dist/node/result-response.js",
				"default": "./dist/result-response.js"
			}
		}
	}
}

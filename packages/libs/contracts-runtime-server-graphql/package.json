{
	"name": "@contractspec/lib.contracts-runtime-server-graphql",
	"version": "3.8.0",
	"description": "GraphQL server runtime adapters for ContractSpec contracts",
	"type": "module",
	"types": "./dist/index.d.ts",
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"clean": "rm -rf dist",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit",
		"dev": "contractspec-bun-build dev"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/contract-runtime-server-graphql"
	},
	"dependencies": {
		"@contractspec/lib.contracts-runtime-server-rest": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.schema": "workspace:*",
		"@pothos/plugin-complexity": "^4.1.2",
		"@pothos/plugin-dataloader": "^4.4.2",
		"@pothos/plugin-prisma": "^4.14.3",
		"@pothos/plugin-relay": "^4.7.0",
		"@pothos/plugin-tracing": "^1.1.2"
	},
	"peerDependencies": {
		"@pothos/core": "^4.9.1",
		"@pothos/plugin-relay": "^4.7.0"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": "./src/index.ts",
		"./contracts-runtime-server-graphql.feature": "./src/contracts-runtime-server-graphql.feature.ts",
		"./graphql-pothos": "./src/graphql-pothos.ts"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./contracts-runtime-server-graphql.feature": {
				"types": "./dist/contracts-runtime-server-graphql.feature.d.ts",
				"browser": "./dist/browser/contracts-runtime-server-graphql.feature.js",
				"bun": "./dist/contracts-runtime-server-graphql.feature.js",
				"node": "./dist/node/contracts-runtime-server-graphql.feature.js",
				"default": "./dist/contracts-runtime-server-graphql.feature.js"
			},
			"./graphql-pothos": {
				"types": "./dist/graphql-pothos.d.ts",
				"browser": "./dist/browser/graphql-pothos.js",
				"bun": "./dist/graphql-pothos.js",
				"node": "./dist/node/graphql-pothos.js",
				"default": "./dist/graphql-pothos.js"
			}
		}
	}
}

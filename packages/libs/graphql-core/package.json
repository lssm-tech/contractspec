{
	"name": "@contractspec/lib.graphql-core",
	"version": "3.7.12",
	"description": "Shared GraphQL core: Pothos builder factory, scalars, tracing & complexity",
	"keywords": [
		"contractspec",
		"graphql",
		"pothos",
		"scalars",
		"tracing",
		"typescript"
	],
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"dev": "contractspec-bun-build dev",
		"clean": "rm -rf dist",
		"prebuild": "contractspec-bun-build prebuild",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@pothos/core": "^4.9.1",
		"@pothos/plugin-complexity": "^4.1.2",
		"@pothos/plugin-dataloader": "^4.4.2",
		"@pothos/plugin-relay": "^4.7.0",
		"@pothos/plugin-tracing": "^1.1.2",
		"graphql": "^16.13.2",
		"graphql-scalars": "^1.22.5"
	},
	"peerDependencies": {
		"graphql": ">=16.13.2"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/graphql-core"
	},
	"homepage": "https://contractspec.io"
}

{
	"name": "@contractspec/lib.error",
	"version": "3.7.14",
	"description": "Structured error handling and HTTP error utilities",
	"keywords": [
		"contractspec",
		"error",
		"handling",
		"http",
		"typescript"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"peerDependencies": {
		"elysia": "^1.4.28",
		"express": "^5.2.1",
		"next": "16.2.3"
	},
	"type": "module",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": "./src/index.ts",
		"./appError": "./src/appError.ts",
		"./codes": "./src/codes.ts",
		"./error.feature": "./src/error.feature.ts",
		"./http": "./src/http.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./appError": {
				"types": "./dist/appError.d.ts",
				"browser": "./dist/browser/appError.js",
				"bun": "./dist/appError.js",
				"node": "./dist/node/appError.js",
				"default": "./dist/appError.js"
			},
			"./codes": {
				"types": "./dist/codes.d.ts",
				"browser": "./dist/browser/codes.js",
				"bun": "./dist/codes.js",
				"node": "./dist/node/codes.js",
				"default": "./dist/codes.js"
			},
			"./error.feature": {
				"types": "./dist/error.feature.d.ts",
				"browser": "./dist/browser/error.feature.js",
				"bun": "./dist/error.feature.js",
				"node": "./dist/node/error.feature.js",
				"default": "./dist/error.feature.js"
			},
			"./http": {
				"types": "./dist/http.d.ts",
				"browser": "./dist/browser/http.js",
				"bun": "./dist/http.js",
				"node": "./dist/node/http.js",
				"default": "./dist/http.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/libs/error"
	},
	"homepage": "https://contractspec.io"
}

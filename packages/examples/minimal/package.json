{
	"name": "@contractspec/example.minimal",
	"version": "2.8.16",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./docs": "./src/docs/index.ts",
		"./docs/minimal.docblock": "./src/docs/minimal.docblock.ts",
		"./example": "./src/example.ts",
		"./minimal.feature": "./src/minimal.feature.ts",
		"./contracts/user": "./src/contracts/user.ts"
	},
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"scaffold": "bun ../../apps/cli-contractspec/src/cli.ts build src/contracts/user.ts",
		"validate": "bun ../../apps/cli-contractspec/src/cli.ts validate src/contracts/user.ts",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"smoke": "bun test src/example.smoke.test.ts",
		"preflight": "bun run build && bun run typecheck && bun run test && bun run validate && bun run smoke"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/examples/minimal"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.schema": "workspace:*"
	}
}

{
	"name": "@contractspec/example.in-app-docs",
	"version": "3.7.15",
	"description": "Example showing how to use DocBlock for in-app documentation for non-technical users",
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./src/index.ts",
		"./docs": "./src/docs/index.ts",
		"./docs/in-app-docs.docblock": "./src/docs/in-app-docs.docblock.ts",
		"./example": "./src/example.ts",
		"./in-app-docs.feature": "./src/in-app-docs.feature.ts",
		"./ui": "./src/ui/index.ts",
		"./ui/InAppDocsViewer": "./src/ui/InAppDocsViewer.tsx"
	},
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run prebuild && bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "biome check --write --unsafe --only=nursery/useSortedClasses . && biome check --write .",
		"lint:check": "biome check .",
		"test": "bun test --pass-with-no-tests",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.example-shared-ui": "workspace:*",
		"react": "catalog:",
		"react-dom": "catalog:"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.2",
		"@contractspec/tool.bun": "workspace:*"
	},
	"publishConfig": {
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./docs": {
				"types": "./dist/docs/index.d.ts",
				"browser": "./dist/browser/docs/index.js",
				"bun": "./dist/docs/index.js",
				"node": "./dist/node/docs/index.js",
				"default": "./dist/docs/index.js"
			},
			"./docs/in-app-docs.docblock": {
				"types": "./dist/docs/in-app-docs.docblock.d.ts",
				"browser": "./dist/browser/docs/in-app-docs.docblock.js",
				"bun": "./dist/docs/in-app-docs.docblock.js",
				"node": "./dist/node/docs/in-app-docs.docblock.js",
				"default": "./dist/docs/in-app-docs.docblock.js"
			},
			"./example": {
				"types": "./dist/example.d.ts",
				"browser": "./dist/browser/example.js",
				"bun": "./dist/example.js",
				"node": "./dist/node/example.js",
				"default": "./dist/example.js"
			},
			"./in-app-docs.feature": {
				"types": "./dist/in-app-docs.feature.d.ts",
				"browser": "./dist/browser/in-app-docs.feature.js",
				"bun": "./dist/in-app-docs.feature.js",
				"node": "./dist/node/in-app-docs.feature.js",
				"default": "./dist/in-app-docs.feature.js"
			},
			"./ui": {
				"types": "./dist/ui/index.d.ts",
				"browser": "./dist/browser/ui/index.js",
				"bun": "./dist/ui/index.js",
				"node": "./dist/node/ui/index.js",
				"default": "./dist/ui/index.js"
			},
			"./ui/InAppDocsViewer": {
				"types": "./dist/ui/InAppDocsViewer.d.ts",
				"browser": "./dist/browser/ui/InAppDocsViewer.js",
				"bun": "./dist/ui/InAppDocsViewer.js",
				"node": "./dist/node/ui/InAppDocsViewer.js",
				"default": "./dist/ui/InAppDocsViewer.js"
			}
		},
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/examples/in-app-docs"
	},
	"homepage": "https://contractspec.io"
}

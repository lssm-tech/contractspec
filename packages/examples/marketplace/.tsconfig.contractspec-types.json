{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@contractspec/lib.schema": [
        "../../libs/schema/dist/index.d.ts"
      ],
      "@contractspec/lib.schema/*": [
        "../../libs/schema/dist/*"
      ],
      "@contractspec/lib.contracts-spec": [
        "../../libs/contracts-spec/dist/index.d.ts"
      ],
      "@contractspec/lib.contracts-spec/*": [
        "../../libs/contracts-spec/dist/*"
      ],
      "@contractspec/lib.example-shared-ui": [
        "../../libs/example-shared-ui/dist/index.d.ts"
      ],
      "@contractspec/lib.example-shared-ui/*": [
        "../../libs/example-shared-ui/dist/*"
      ],
      "@contractspec/lib.design-system": [
        "../../libs/design-system/dist/index.d.ts"
      ],
      "@contractspec/lib.design-system/*": [
        "../../libs/design-system/dist/*"
      ],
      "@contractspec/lib.runtime-sandbox": [
        "../../libs/runtime-sandbox/dist/index.d.ts"
      ],
      "@contractspec/lib.runtime-sandbox/*": [
        "../../libs/runtime-sandbox/dist/*"
      ],
      "@contractspec/tool.typescript/*": [
        "../../tools/typescript/dist/*"
      ],
      "@contractspec/tool.bun/*": [
        "../../tools/bun/dist/*"
      ]
    }
  }
}

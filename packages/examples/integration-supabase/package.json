{
	"name": "@contractspec/example.integration-supabase",
	"version": "3.7.20",
	"description": "Integration example - Supabase vector store + Postgres database wiring.",
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./src/index.ts",
		"./blueprint": "./src/blueprint.ts",
		"./connection.sample": "./src/connection.sample.ts",
		"./docs": "./src/docs/index.ts",
		"./docs/integration-supabase.docblock": "./src/docs/integration-supabase.docblock.ts",
		"./example": "./src/example.ts",
		"./integration-supabase.feature": "./src/integration-supabase.feature.ts",
		"./runtime.sample": "./src/runtime.sample.ts",
		"./tenant": "./src/tenant.ts"
	},
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"test": "bun test --pass-with-no-tests",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/integration.providers-impls": "workspace:*",
		"@contractspec/integration.runtime": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.contracts-integrations": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./blueprint": {
				"types": "./dist/blueprint.d.ts",
				"browser": "./dist/browser/blueprint.js",
				"bun": "./dist/blueprint.js",
				"node": "./dist/node/blueprint.js",
				"default": "./dist/blueprint.js"
			},
			"./connection.sample": {
				"types": "./dist/connection.sample.d.ts",
				"browser": "./dist/browser/connection.sample.js",
				"bun": "./dist/connection.sample.js",
				"node": "./dist/node/connection.sample.js",
				"default": "./dist/connection.sample.js"
			},
			"./docs": {
				"types": "./dist/docs/index.d.ts",
				"browser": "./dist/browser/docs/index.js",
				"bun": "./dist/docs/index.js",
				"node": "./dist/node/docs/index.js",
				"default": "./dist/docs/index.js"
			},
			"./docs/integration-supabase.docblock": {
				"types": "./dist/docs/integration-supabase.docblock.d.ts",
				"browser": "./dist/browser/docs/integration-supabase.docblock.js",
				"bun": "./dist/docs/integration-supabase.docblock.js",
				"node": "./dist/node/docs/integration-supabase.docblock.js",
				"default": "./dist/docs/integration-supabase.docblock.js"
			},
			"./example": {
				"types": "./dist/example.d.ts",
				"browser": "./dist/browser/example.js",
				"bun": "./dist/example.js",
				"node": "./dist/node/example.js",
				"default": "./dist/example.js"
			},
			"./integration-supabase.feature": {
				"types": "./dist/integration-supabase.feature.d.ts",
				"browser": "./dist/browser/integration-supabase.feature.js",
				"bun": "./dist/integration-supabase.feature.js",
				"node": "./dist/node/integration-supabase.feature.js",
				"default": "./dist/integration-supabase.feature.js"
			},
			"./runtime.sample": {
				"types": "./dist/runtime.sample.d.ts",
				"browser": "./dist/browser/runtime.sample.js",
				"bun": "./dist/runtime.sample.js",
				"node": "./dist/node/runtime.sample.js",
				"default": "./dist/runtime.sample.js"
			},
			"./tenant": {
				"types": "./dist/tenant.d.ts",
				"browser": "./dist/browser/tenant.js",
				"bun": "./dist/tenant.js",
				"node": "./dist/node/tenant.js",
				"default": "./dist/tenant.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/examples/integration-supabase"
	},
	"homepage": "https://contractspec.io"
}

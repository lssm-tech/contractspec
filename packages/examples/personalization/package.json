{
	"name": "@contractspec/example.personalization",
	"version": "3.7.26",
	"description": "Personalization examples: behavior tracking, overlay customization, workflow extension.",
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./src/index.ts",
		"./behavior-tracking": "./src/behavior-tracking.ts",
		"./docs": "./src/docs/index.ts",
		"./docs/personalization.docblock": "./src/docs/personalization.docblock.ts",
		"./example": "./src/example.ts",
		"./overlay-customization": "./src/overlay-customization.ts",
		"./personalization.experiment": "./src/personalization.experiment.ts",
		"./personalization.feature": "./src/personalization.feature.ts",
		"./personalization.theme": "./src/personalization.theme.ts",
		"./workflow-extension": "./src/workflow-extension.ts"
	},
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"test": "bun test --pass-with-no-tests",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/lib.personalization": "workspace:*",
		"@contractspec/lib.overlay-engine": "workspace:*",
		"@contractspec/lib.workflow-composer": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.logger": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:",
		"@contractspec/tool.bun": "workspace:*"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"browser": "./dist/browser/index.js",
				"bun": "./dist/index.js",
				"node": "./dist/node/index.js",
				"default": "./dist/index.js"
			},
			"./behavior-tracking": {
				"types": "./dist/behavior-tracking.d.ts",
				"browser": "./dist/browser/behavior-tracking.js",
				"bun": "./dist/behavior-tracking.js",
				"node": "./dist/node/behavior-tracking.js",
				"default": "./dist/behavior-tracking.js"
			},
			"./docs": {
				"types": "./dist/docs/index.d.ts",
				"browser": "./dist/browser/docs/index.js",
				"bun": "./dist/docs/index.js",
				"node": "./dist/node/docs/index.js",
				"default": "./dist/docs/index.js"
			},
			"./docs/personalization.docblock": {
				"types": "./dist/docs/personalization.docblock.d.ts",
				"browser": "./dist/browser/docs/personalization.docblock.js",
				"bun": "./dist/docs/personalization.docblock.js",
				"node": "./dist/node/docs/personalization.docblock.js",
				"default": "./dist/docs/personalization.docblock.js"
			},
			"./example": {
				"types": "./dist/example.d.ts",
				"browser": "./dist/browser/example.js",
				"bun": "./dist/example.js",
				"node": "./dist/node/example.js",
				"default": "./dist/example.js"
			},
			"./overlay-customization": {
				"types": "./dist/overlay-customization.d.ts",
				"browser": "./dist/browser/overlay-customization.js",
				"bun": "./dist/overlay-customization.js",
				"node": "./dist/node/overlay-customization.js",
				"default": "./dist/overlay-customization.js"
			},
			"./personalization.experiment": {
				"types": "./dist/personalization.experiment.d.ts",
				"browser": "./dist/browser/personalization.experiment.js",
				"bun": "./dist/personalization.experiment.js",
				"node": "./dist/node/personalization.experiment.js",
				"default": "./dist/personalization.experiment.js"
			},
			"./personalization.feature": {
				"types": "./dist/personalization.feature.d.ts",
				"browser": "./dist/browser/personalization.feature.js",
				"bun": "./dist/personalization.feature.js",
				"node": "./dist/node/personalization.feature.js",
				"default": "./dist/personalization.feature.js"
			},
			"./personalization.theme": {
				"types": "./dist/personalization.theme.d.ts",
				"browser": "./dist/browser/personalization.theme.js",
				"bun": "./dist/personalization.theme.js",
				"node": "./dist/node/personalization.theme.js",
				"default": "./dist/personalization.theme.js"
			},
			"./workflow-extension": {
				"types": "./dist/workflow-extension.d.ts",
				"browser": "./dist/browser/workflow-extension.js",
				"bun": "./dist/workflow-extension.js",
				"node": "./dist/node/workflow-extension.js",
				"default": "./dist/workflow-extension.js"
			}
		},
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/examples/personalization"
	},
	"homepage": "https://contractspec.io"
}

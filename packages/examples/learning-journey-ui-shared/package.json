	"exports": {
		".": "./src/index.ts",
		"./components": "./src/components/index.ts",
		"./components/BadgeDisplay": "./src/components/BadgeDisplay.tsx",
		"./components/StreakCounter": "./src/components/StreakCounter.tsx",

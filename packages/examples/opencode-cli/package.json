{
	"name": "@contractspec/example.opencode-cli",
	"version": "2.8.21",
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./contracts/opencode": "./src/contracts/opencode.contracts.ts",
		"./docs": "./src/docs/index.ts",
		"./docs/opencode-cli.docblock": "./src/docs/opencode-cli.docblock.ts",
		"./example": "./src/example.ts",
		"./opencode-cli.feature": "./src/opencode-cli.feature.ts"
	},
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"scaffold": "bun ../../apps/cli-contractspec/src/cli.ts build src/contracts/opencode.contracts.ts --agent-mode opencode",
		"validate": "bun ../../apps/cli-contractspec/src/cli.ts validate src/contracts/opencode.contracts.ts --check-implementation --agent-mode opencode",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"smoke": "bun test src/example.smoke.test.ts",
		"preflight": "bun run build && bun run typecheck && bun run test && bun run validate && bun run smoke"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.schema": "workspace:*"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/examples/opencode-cli"
	}
}

{
	"name": "@contractspec/example.harness-lab",
	"version": "3.7.15",
	"description": "Focused harness example for ContractSpec scenarios, suites, orchestration, and runtime adapters.",
	"type": "module",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./src/index.ts",
		"./docs": "./src/docs/index.ts",
		"./docs/harness-lab.docblock": "./src/docs/harness-lab.docblock.ts",
		"./example": "./src/example.ts",
		"./harness-lab.feature": "./src/harness-lab.feature.ts",
		"./runtime": "./src/runtime/index.ts",
		"./runtime/browserFixtureServer": "./src/runtime/browserFixtureServer.ts",
		"./runtime/createHarnessLabEvaluationTools": "./src/runtime/createHarnessLabEvaluationTools.ts",
		"./runtime/runBrowserEvaluation": "./src/runtime/runBrowserEvaluation.ts",
		"./runtime/runSandboxEvaluation": "./src/runtime/runSandboxEvaluation.ts",
		"./scenarios": "./src/scenarios/index.ts",
		"./scenarios/harnessLabBrowser.scenario": "./src/scenarios/harnessLabBrowser.scenario.ts",
		"./scenarios/harnessLabSandbox.scenario": "./src/scenarios/harnessLabSandbox.scenario.ts",
		"./suite": "./src/suite/index.ts",
		"./suite/harnessLabDualMode.suite": "./src/suite/harnessLabDualMode.suite.ts"
	},
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run build:bundle && bun run build:types",
		"build:bundle": "contractspec-bun-build transpile",
		"build:types": "contractspec-bun-build types",
		"dev": "contractspec-bun-build dev",
		"clean": "rimraf dist .turbo",
		"lint": "bun lint:fix",
		"lint:fix": "biome check --write --unsafe --only=nursery/useSortedClasses . && biome check --write .",
		"lint:check": "biome check .",
		"test": "bun test",
		"prebuild": "contractspec-bun-build prebuild",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@contractspec/integration.harness-runtime": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.harness": "workspace:*"
	},
	"peerDependencies": {
		"playwright": "^1.54.0"
	},
	"peerDependenciesMeta": {
		"playwright": {
			"optional": true
		}
	},
	"devDependencies": {
		"@contractspec/tool.bun": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"playwright": "^1.54.0",
		"typescript": "catalog:"
	},

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "incremental": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": false,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@contractspec/lib.ai-agent": [
        "../../libs/ai-agent/dist/index.d.ts"
      ],
      "@contractspec/lib.ai-agent/*": [
        "../../libs/ai-agent/dist/*"
      ],
      "@contractspec/lib.contracts-spec": [
        "../../libs/contracts-spec/dist/index.d.ts"
      ],
      "@contractspec/lib.contracts-spec/*": [
        "../../libs/contracts-spec/dist/*"
      ],
      "@contractspec/lib.schema": [
        "../../libs/schema/dist/index.d.ts"
      ],
      "@contractspec/lib.schema/*": [
        "../../libs/schema/dist/*"
      ],
      "@contractspec/module.ai-chat": [
        "../../modules/ai-chat/dist/index.d.ts"
      ],
      "@contractspec/module.ai-chat/*": [
        "../../modules/ai-chat/dist/*"
      ],
      "@contractspec/tool.typescript/*": [
        "../../tools/typescript/dist/*"
      ],
      "@contractspec/tool.bun/*": [
        "../../tools/bun/dist/*"
      ]
    }
  }
}

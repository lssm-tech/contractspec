{
  "name": "@contractspec/example.visualization-showcase",
  "version": "3.8.0",
  "description": "Focused visualization showcase for ContractSpec primitives and design-system wrappers",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts",
    "./docs": "./src/docs/index.ts",
    "./docs/visualization-showcase.docblock": "./src/docs/visualization-showcase.docblock.ts",
    "./example": "./src/example.ts",
    "./ui": "./src/ui/index.ts",
    "./ui/VisualizationShowcase": "./src/ui/VisualizationShowcase.tsx",
    "./ui/renderers": "./src/ui/renderers/index.ts",
    "./ui/renderers/visualization-showcase.markdown": "./src/ui/renderers/visualization-showcase.markdown.ts",
    "./visualization-showcase.feature": "./src/visualization-showcase.feature.ts",
    "./visualizations": "./src/visualizations/index.ts"
  },
  "scripts": {
    "publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
    "publish:pkg:canary": "bun publish:pkg --tag canary",
    "build": "bun run prebuild && bun run build:bundle && bun run build:types",
    "build:bundle": "contractspec-bun-build transpile",
    "build:types": "contractspec-bun-build types",
    "dev": "contractspec-bun-build dev",
    "clean": "rimraf dist .turbo",
    "lint": "bun lint:fix",
    "lint:fix": "biome check --write --unsafe --only=nursery/useSortedClasses . && biome check --write .",
    "lint:check": "biome check .",
    "test": "bun test",
    "prebuild": "contractspec-bun-build prebuild",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contractspec/lib.contracts-spec": "workspace:*",
    "@contractspec/lib.design-system": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@contractspec/tool.typescript": "workspace:*",
    "typescript": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.2",
    "@contractspec/tool.bun": "workspace:*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "browser": "./dist/browser/index.js",
        "bun": "./dist/index.js",

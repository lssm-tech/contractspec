{
	"name": "@contractspec/app.api-library",
	"version": "3.8.13",
	"private": true,
	"scripts": {
		"clean": "rm -rf dist api/dist",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"dev": "bun run --watch src/index.ts",
		"build": "bun run prebuild && bun run build:types && bun run build:bundle",
		"build:bundle": "bun build --target node --packages bundle --outfile dist/index.js src/index.ts && mkdir -p api/dist && cp dist/index.js api/dist/index.js",
		"build:types": "tsc -p ./tsconfig.json --noEmit",
		"prebuild": "bun ../../../scripts/generate-contractsrc-schema.ts",
		"typecheck": "bun run build:types",
		"test": "bun test",
		"postinstall": "if [ \"$VERCEL\" = \"1\" ]; then bun run build:bundle; fi",
		"start": "bun run ./dist/index.js"
	},
	"dependencies": {
		"@contractspec/bundle.library": "workspace:*",
		"@contractspec/bundle.marketing": "workspace:*",
		"@contractspec/bundle.workspace": "workspace:*",
		"@contractspec/integration.builder-telegram": "workspace:*",
		"@contractspec/integration.builder-whatsapp": "workspace:*",
		"@contractspec/integration.provider.codex": "workspace:*",
		"@contractspec/integration.providers-impls": "workspace:*",
		"@contractspec/integration.runtime": "workspace:*",
		"@contractspec/integration.runtime.managed": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"elysia": "^1.4.28",
		"pg": "^8.20.0",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@contractspec/tool.typescript": "workspace:*",
		"typescript": "catalog:"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	}
}

{
	"name": "@contractspec/app.expo-demo",
	"version": "1.1.17",
	"private": true,
	"description": "Minimal Expo React Native app - Task List demo for ContractSpec mobile runtime",
	"scripts": {
		"dev": "expo start",
		"start": "expo start",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"lint": "bun run lint:fix",

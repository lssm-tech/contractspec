		"test": "bun test"
	},
	"dependencies": {
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.presentation-runtime-core": "workspace:*",
		"@contractspec/lib.presentation-runtime-react-native": "workspace:*",
		"@contractspec/lib.schema": "workspace:*",
		"@contractspec/lib.ui-kit": "workspace:*",
		"@contractspec/lib.ui-kit-core": "workspace:*",
		"@react-native-async-storage/async-storage": "^2.1.2",
		"burnt": "^0.13.0",
		"expo": "^55.0.0",
		"expo-router": "~55.0.5",
		"expo-status-bar": "~55.0.4",
		"expo-system-ui": "~55.0.9",
		"expo-updates": "~55.0.12",
		"lucide-react-native": "^0.577.0",
		"nativewind": "4.2.1",
		"react": "19.2.0",
		"react-native": "0.83.2",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0"
	},
	"devDependencies": {

{
	"name": "@contractspec/app.registry-packs",
	"version": "1.7.18",
	"type": "module",
	"module": "src/index.ts",
	"scripts": {
		"clean": "rm -rf dist",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"dev": "bun run --watch src/index.ts",
		"build": "bun build --minify-whitespace --minify-syntax --target bun --outfile dist/index.js src/index.ts --external '@modelcontextprotocol/sdk' --external 'pg' --external 'drizzle-orm' --external 'drizzle-orm/*'",
		"start": "bun run ./dist/index.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:generate:pg": "drizzle-kit generate --config=drizzle-pg.config.ts",
		"db:migrate:pg": "drizzle-kit migrate --config=drizzle-pg.config.ts",
		"db:seed": "bun run src/db/seed.ts",
		"test": "bun test --pass-with-no-tests"
	},
	"dependencies": {
		"@elysiajs/cors": "^1.4.1",
		"@elysiajs/server-timing": "^1.4.0",
		"@modelcontextprotocol/sdk": "catalog:ai",
		"drizzle-orm": "catalog:data",
		"elysia": "catalog:server",
		"zod": "catalog:",
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"optionalDependencies": {
		"pg": "catalog:server"
	},
	"devDependencies": {
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "catalog:"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/apps/registry-packs"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"homepage": "https://agentpacks.dev",
	"exports": {
		".": "./src/index.ts"
	}
}

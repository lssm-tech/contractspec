{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"$schema": {
			"type": "string",
			"format": "uri-reference",
			"description": "JSON Schema location for editor validation and completions."
		},
		"aiProvider": {
			"default": "claude",
			"type": "string",
			"enum": ["claude", "openai", "ollama", "mistral", "custom"]
		},
		"aiModel": {
			"type": "string"
		},
		"agentMode": {
			"default": "simple",
			"type": "string",
			"enum": [
				"simple",
				"cursor",
				"claude-code",
				"openai-codex",
				"claude-agent-sdk",
				"opencode",
				"opencode-sdk"
			]
		},
		"customEndpoint": {
			"anyOf": [
				{
					"type": "string",
					"format": "uri"
				},
				{
					"type": "null"
				}
			]
		},
		"customApiKey": {
			"anyOf": [
				{
					"type": "string"
				},
				{
					"type": "null"
				}
			]
		},
		"outputDir": {
			"default": "./src",
			"type": "string"
		},
		"conventions": {
			"type": "object",
			"properties": {
				"models": {
					"default": "models",
					"type": "string"
				},
				"operations": {
					"default": "operations/commands|queries",
					"type": "string"
				},
				"events": {
					"default": "events",
					"type": "string"
				},
				"presentations": {
					"default": "presentations",
					"type": "string"
				},
				"forms": {
					"default": "forms",
					"type": "string"
				},
				"capabilities": {
					"default": "capabilities",
					"type": "string"
				},
				"policies": {
					"default": "policies",
					"type": "string"
				},
				"tests": {
					"default": "tests",
					"type": "string"
				},
				"translations": {
					"default": "translations",
					"type": "string"
				},
				"groupByFeature": {
					"default": true,
					"type": "boolean"
				},
				"operationsGrouping": {
					"type": "object",
					"properties": {
						"strategy": {
							"type": "string",
							"enum": [
								"by-tag",
								"by-owner",
								"by-domain",
								"by-url-path-single",
								"by-url-path-multi",
								"by-feature",
								"none"
							]
						},
						"urlPathLevel": {
							"type": "number"
						},
						"pattern": {
							"type": "string"
						}
					},
					"required": ["strategy"],
					"additionalProperties": false
				},
				"modelsGrouping": {
					"type": "object",
					"properties": {
						"strategy": {
							"type": "string",
							"enum": [
								"by-tag",
								"by-owner",
								"by-domain",
								"by-url-path-single",
								"by-url-path-multi",
								"by-feature",
								"none"
							]
						},
						"urlPathLevel": {
							"type": "number"
						},
						"pattern": {
							"type": "string"
						}
					},
					"required": ["strategy"],
					"additionalProperties": false
				},
				"eventsGrouping": {
					"type": "object",
					"properties": {
						"strategy": {
							"type": "string",
							"enum": [
								"by-tag",
								"by-owner",
								"by-domain",
								"by-url-path-single",
								"by-url-path-multi",
								"by-feature",
								"none"
							]
						},
						"urlPathLevel": {
							"type": "number"
						},
						"pattern": {
							"type": "string"
						}
					},
					"required": ["strategy"],
					"additionalProperties": false
				}
			},
			"additionalProperties": false
		},
		"defaultOwners": {
			"default": [],
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"defaultTags": {
			"default": [],
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"packages": {
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"excludePackages": {
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"recursive": {
			"type": "boolean"
		},
		"openapi": {
			"type": "object",
			"properties": {
				"sources": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"name": {
								"type": "string"
							},
							"url": {
								"type": "string",
								"format": "uri"
							},
							"file": {
								"type": "string"
							},
							"syncMode": {
								"default": "validate",
								"type": "string",
								"enum": ["import", "sync", "validate"]
							},
							"tags": {
								"type": "array",
								"items": {
									"type": "string"
								}
							},
							"exclude": {
								"type": "array",
								"items": {
									"type": "string"
								}
							},
							"include": {
								"type": "array",
								"items": {
									"type": "string"
								}
							},
							"prefix": {
								"type": "string"
							},
							"defaultStability": {
								"type": "string",
								"enum": ["experimental", "beta", "stable", "deprecated"]
							},
							"defaultAuth": {
								"type": "string",
								"enum": ["anonymous", "user", "admin"]
							},
							"defaultOwners": {
								"type": "array",
								"items": {
									"type": "string"
								}
							},
							"schemaFormat": {
								"default": "contractspec",
								"type": "string",
								"enum": ["contractspec", "zod", "json-schema", "graphql"]
							}
						},
						"required": ["name"],
						"additionalProperties": false
					}
				},
				"export": {
					"type": "object",
					"properties": {
						"outputPath": {
							"default": "./openapi.json",
							"type": "string"
						},
						"format": {
							"default": "json",
							"type": "string",
							"enum": ["json", "yaml"]
						},
						"title": {
							"type": "string"
						},
						"version": {
							"type": "string"
						},
						"description": {
							"type": "string"
						},
						"servers": {
							"type": "array",
							"items": {
								"type": "object",
								"properties": {
									"url": {
										"type": "string"
									},
									"description": {
										"type": "string"
									}
								},
								"required": ["url"],
								"additionalProperties": false
							}
						}
					},
					"additionalProperties": false
				}
			},
			"additionalProperties": false
		},
		"ci": {
			"type": "object",
			"properties": {
				"checks": {
					"default": ["structure", "integrity", "deps"],
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"skipChecks": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"failOnWarnings": {
					"default": false,
					"type": "boolean"
				},
				"uploadSarif": {
					"default": true,
					"type": "boolean"
				},
				"prComment": {
					"type": "object",
					"properties": {
						"enabled": {
							"default": true,
							"type": "boolean"
						},
						"template": {
							"default": "detailed",
							"type": "string",
							"enum": ["minimal", "detailed"]
						},
						"updateExisting": {
							"default": true,
							"type": "boolean"
						}
					},
					"additionalProperties": false
				},
				"checkRun": {
					"type": "object",
					"properties": {
						"enabled": {
							"default": true,
							"type": "boolean"
						},
						"name": {
							"default": "ContractSpec Impact",
							"type": "string"
						},
						"failOnBreaking": {
							"default": true,
							"type": "boolean"
						},
						"failOnChanges": {
							"default": false,
							"type": "boolean"
						}
					},
					"additionalProperties": false
				},
				"impact": {
					"type": "object",
					"properties": {
						"baseline": {
							"default": "default-branch",
							"type": "string"
						},
						"include": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"exclude": {
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					},
					"additionalProperties": false
				},
				"packageDeclarations": {
					"type": "object",
					"properties": {
						"severity": {
							"default": "error",
							"type": "string",
							"enum": ["off", "warning", "error"]
						},
						"requiredByKind": {
							"type": "object",
							"properties": {
								"libs": {
									"default": "feature",
									"type": "string",
									"enum": [
										"feature",
										"integration",
										"app-config",
										"module-bundle",
										"example"
									]
								},
								"modules": {
									"default": "feature",
									"type": "string",
									"enum": [
										"feature",
										"integration",
										"app-config",
										"module-bundle",
										"example"
									]
								},
								"integrations": {
									"default": "integration",
									"type": "string",
									"enum": [
										"feature",
										"integration",
										"app-config",
										"module-bundle",
										"example"
									]
								},
								"bundles": {
									"default": "module-bundle",
									"type": "string",
									"enum": [
										"feature",
										"integration",
										"app-config",
										"module-bundle",
										"example"
									]
								},
								"apps": {
									"default": "app-config",
									"type": "string",
									"enum": [
										"feature",
										"integration",
										"app-config",
										"module-bundle",
										"example"
									]
								},
								"appsRegistry": {
									"default": "app-config",
									"type": "string",
									"enum": [
										"feature",
										"integration",
										"app-config",
										"module-bundle",
										"example"
									]
								},
								"examples": {
									"default": "example",
									"type": "string",
									"enum": [
										"feature",
										"integration",
										"app-config",
										"module-bundle",
										"example"
									]
								}
							},
							"additionalProperties": false
						},
						"allowMissing": {
							"default": [],
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					},
					"additionalProperties": false
				}
			},
			"additionalProperties": false
		},
		"metaRepo": {
			"type": "object",
			"properties": {
				"activeScope": {
					"type": "string"
				},
				"externalWorkspaces": {
					"type": "array",
					"items": {
						"type": "object",
						"properties": {
							"alias": {
								"type": "string"
							},
							"submodule": {
								"type": "string"
							},
							"packages": {
								"type": "array",
								"items": {
									"type": "string"
								}
							},
							"autoResolve": {
								"default": true,
								"type": "boolean"
							}
						},
						"required": ["alias", "submodule"],
						"additionalProperties": false
					}
				},
				"crossWorkspaceSearch": {
					"default": false,
					"type": "boolean"
				}
			},
			"additionalProperties": false
		},
		"rules": {
			"type": "object",
			"properties": {
				"defaults": {
					"type": "object",
					"properties": {
						"require-acceptance": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"require-examples": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"require-stability": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"require-owners-format": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"event-past-tense": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"no-todo": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"workflow-transitions": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"telemetry-privacy": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"experiment-allocation": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"app-config-appid": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"app-config-capabilities": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						},
						"data-view-fields": {
							"type": "string",
							"enum": ["off", "warn", "error"]
						}
					},
					"additionalProperties": false
				},
				"overrides": {
					"type": "object",
					"propertyNames": {
						"type": "string",
						"enum": [
							"operation",
							"event",
							"presentation",
							"feature",
							"capability",
							"data-view",
							"visualization",
							"form",
							"agent",
							"migration",
							"workflow",
							"experiment",
							"integration",
							"theme",
							"knowledge",
							"telemetry",
							"example",
							"app-config",
							"product-intent",
							"policy",
							"test-spec",
							"harness-scenario",
							"harness-suite",
							"type",
							"knowledge-space",
							"job",
							"translation"
						]
					},
					"additionalProperties": {
						"type": "object",
						"properties": {
							"require-acceptance": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"require-examples": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"require-stability": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"require-owners-format": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"event-past-tense": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"no-todo": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"workflow-transitions": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"telemetry-privacy": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"experiment-allocation": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"app-config-appid": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"app-config-capabilities": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							},
							"data-view-fields": {
								"type": "string",
								"enum": ["off", "warn", "error"]
							}
						},
						"additionalProperties": false
					},
					"required": [
						"operation",
						"event",
						"presentation",
						"feature",
						"capability",
						"data-view",
						"visualization",
						"form",
						"agent",
						"migration",
						"workflow",
						"experiment",
						"integration",
						"theme",
						"knowledge",
						"telemetry",
						"example",
						"app-config",
						"product-intent",
						"policy",
						"test-spec",
						"harness-scenario",
						"harness-suite",
						"type",
						"knowledge-space",
						"job",
						"translation"
					]
				}
			},
			"additionalProperties": false
		},
		"testing": {
			"type": "object",
			"properties": {
				"runner": {
					"default": "internal",
					"type": "string",
					"enum": ["internal", "jest", "vitest", "bun"]
				},
				"testMatch": {
					"default": ["**/*.{test,spec}.{ts,js}"],
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"autoGenerate": {
					"default": false,
					"type": "boolean"
				},
				"integrity": {
					"type": "object",
					"properties": {
						"requireTestsFor": {
							"type": "array",
							"items": {
								"type": "string",
								"enum": [
									"operation",
									"event",
									"presentation",
									"feature",
									"capability",
									"data-view",
									"visualization",
									"form",
									"agent",
									"migration",
									"workflow",
									"experiment",
									"integration",
									"theme",
									"knowledge",
									"telemetry",
									"example",
									"app-config",
									"product-intent",
									"policy",
									"test-spec",
									"harness-scenario",
									"harness-suite",
									"type",
									"knowledge-space",
									"job",
									"translation"
								]
							}
						},
						"minCoverage": {
							"type": "number"
						}
					},
					"additionalProperties": false
				},
				"testLinking": {
					"type": "object",
					"properties": {
						"strategy": {
							"default": "both",
							"type": "string",
							"enum": ["target-first", "convention-only", "both"]
						},
						"warnOnConvention": {
							"default": false,
							"type": "boolean"
						}
					},
					"additionalProperties": false
				},
				"harness": {
					"type": "object",
					"properties": {
						"artifactRoot": {
							"default": ".contractspec/harness",
							"type": "string"
						},
						"browserEngine": {
							"default": "playwright",
							"type": "string",
							"enum": ["playwright", "agent-browser", "both"]
						},
						"targetBaseUrls": {
							"type": "object",
							"properties": {
								"preview": {
									"type": "string",
									"format": "uri"
								},
								"task": {
									"type": "string",
									"format": "uri"
								},
								"shared": {
									"type": "string",
									"format": "uri"
								},
								"sandbox": {
									"type": "string",
									"format": "uri"
								}
							},
							"additionalProperties": false
						},
						"allowlistedDomains": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"visual": {
							"type": "object",
							"properties": {
								"maxDiffBytes": {
									"type": "integer",
									"minimum": 0,
									"maximum": 9007199254740991
								},
								"maxDiffRatio": {
									"type": "number",
									"minimum": 0,
									"maximum": 1
								},
								"updateBaselines": {
									"default": false,
									"type": "boolean"
								}
							},
							"additionalProperties": false
						},
						"authProfiles": {
							"type": "object",
							"propertyNames": {
								"type": "string"
							},
							"additionalProperties": {
								"type": "object",
								"properties": {
									"kind": {
										"type": "string",
										"enum": [
											"storage-state",
											"browser-profile",
											"session-name",
											"headers-env"
										]
									},
									"ref": {
										"type": "string",
										"minLength": 1
									}
								},
								"required": ["kind", "ref"],
								"additionalProperties": false
							}
						}
					},
					"additionalProperties": false
				}
			},
			"additionalProperties": false
		},
		"hooks": {
			"type": "object",
			"propertyNames": {
				"type": "string"
			},
			"additionalProperties": {
				"type": "array",
				"items": {
					"type": "string"
				}
			}
		},
		"schemaFormat": {
			"default": "contractspec",
			"type": "string",
			"enum": ["contractspec", "zod", "json-schema", "graphql"]
		},
		"formatter": {
			"type": "object",
			"properties": {
				"enabled": {
					"default": true,
					"type": "boolean"
				},
				"type": {
					"type": "string",
					"enum": ["biome", "dprint", "custom"]
				},
				"command": {
					"type": "string"
				},
				"args": {
					"type": "array",
					"items": {
						"type": "string"
					}
				},
				"timeout": {
					"default": 30000,
					"type": "number"
				}
			},
			"additionalProperties": false
		},

{
	"name": "@contractspec/app.cli-contractspec",
	"version": "6.0.1",
	"description": "CLI tool for creating, building, and validating contract specifications",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"contractspec": "./dist/node/cli.js"
	},
	"exports": {
		"./run": {
			"bun": "./dist/bun/cli.js",
			"node": "./dist/node/cli.js",
			"default": "./dist/node/cli.js"
		},
		".": "./src/index.ts"
	},
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"build": "bun run prebuild && bun run build:types && bun run build:all",
		"build:bun": "bun build --outdir ./dist/bun/ --target bun --minify --external playwright --external playwright-core --external electron --external chromium-bidi --external 'chromium-bidi/*' ./src/cli.ts",
		"build:node": "bun build --outdir ./dist/node/ --target node --minify --external playwright --external playwright-core --external electron --external chromium-bidi --external 'chromium-bidi/*' ./src/cli.ts",
		"build:all": "bun run build:bun && bun run build:node",
		"build:types": "tsc --noEmit",
		"prebuild": "bun ../../../scripts/generate-contractsrc-schema.ts",
		"typecheck": "tsc --noEmit",
		"dev": "bun build ./src/cli.ts --outfile ./dist/cli.js --target node --watch --external playwright --external playwright-core --external electron --external chromium-bidi --external 'chromium-bidi/*'",
		"dev:bun": "bun build ./src/cli.ts --outfile ./dist/cli.bun.js --target bun --watch --external playwright --external playwright-core --external electron --external chromium-bidi --external 'chromium-bidi/*'",
		"clean": "rimraf dist",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"test": "bun test",
		"test:watch": "bun test --watch"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "catalog:ai",
		"@ai-sdk/mistral": "catalog:ai",
		"@ai-sdk/openai": "catalog:ai",
		"@contractspec/bundle.workspace": "workspace:*",
		"@contractspec/lib.ai-agent": "workspace:*",
		"@contractspec/lib.ai-providers": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*",
		"@contractspec/lib.contracts-transformers": "workspace:*",
		"@contractspec/integration.runtime": "workspace:*",
		"@contractspec/integration.harness-runtime": "workspace:*",
		"@contractspec/lib.plugins": "workspace:*",
		"@contractspec/lib.schema": "workspace:*",
		"@contractspec/lib.testing": "workspace:*",
		"@contractspec/lib.harness": "workspace:*",
		"@contractspec/module.ai-chat": "workspace:*",
		"@contractspec/module.examples": "workspace:*",
		"@contractspec/module.workspace": "workspace:*",
		"@inquirer/prompts": "^8.4.1",
		"ai": "catalog:ai",
		"chalk": "^5.6.2",
		"commander": "^14.0.2",
		"glob": "catalog:build",
		"js-yaml": "^4.1.1",
		"ollama-ai-provider": "catalog:ai",
		"ora": "^9.3.0",
		"pg": "^8.16.3",
		"typescript": "catalog:",
		"zod": "catalog:",
		"@contractspec/lib.contracts-integrations": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.tsdown": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.6.0",
		"@types/sarif": "^2.1.7",
		"rimraf": "catalog:build"
	},
	"keywords": [
		"cli",
		"contracts",
		"code-generation",
		"ai",
		"typescript"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/apps/cli-contractspec"
	},
	"homepage": "https://contractspec.io"
}

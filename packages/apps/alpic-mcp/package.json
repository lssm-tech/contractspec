{
	"name": "@contractspec/app.alpic-mcp",
	"version": "3.7.17",
	"type": "module",
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary",
		"clean": "rm -rf dist",
		"lint": "bun run lint:fix",
		"lint:fix": "node ../../../scripts/biome.cjs check --write --unsafe --only=nursery/useSortedClasses . && node ../../../scripts/biome.cjs check --write .",
		"lint:check": "node ../../../scripts/biome.cjs check .",
		"build": "bun ../../../scripts/tsdown.mjs && mkdir -p dist && cp -R assets dist/assets",
		"dev": "bun ../../../scripts/tsdown.mjs --watch",
		"start": "node dist/server.js"
	},
	"dependencies": {
		"@contractspec/bundle.alpic": "workspace:*",
		"@contractspec/lib.logger": "workspace:*"
	},
	"devDependencies": {
		"@contractspec/tool.tsdown": "workspace:*",
		"@contractspec/tool.typescript": "workspace:*",
		"@types/node": "^25.6.0",
		"tsdown": "catalog:build",
		"typescript": "catalog:"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/apps/alpic-mcp"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/",
		"access": "public"
	},
	"homepage": "https://contractspec.io",
	"exports": {
		".": "./dist/index.mjs",
		"./server": "./dist/server.mjs",
		"./*": "./*"
	}
}

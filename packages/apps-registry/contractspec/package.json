{
	"name": "contractspec",
	"version": "4.0.12",
	"description": "CLI tool for creating, building, and validating contract specifications",
	"bin": {
		"contractspec": "./bin/contractspec.mjs"
	},
	"dependencies": {
		"@contractspec/app.cli-contractspec": "workspace:*",
		"@contractspec/lib.contracts-spec": "workspace:*"
	},
	"files": [
		"bin",
		"contractsrc.schema.json",
		"README.md"
	],
	"scripts": {
		"publish:pkg": "bun publish --tolerate-republish --ignore-scripts --verbose",
		"publish:pkg:canary": "bun publish:pkg --tag canary"
	},
	"keywords": [
		"cli",
		"contracts",
		"code-generation",
		"ai",
		"typescript"
	],
	"publishConfig": {
		"name": "contractspec",
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"license": "MIT",
	"homepage": "https://contractspec.io",
	"repository": {
		"type": "git",
		"url": "https://github.com/lssm-tech/contractspec.git",
		"directory": "packages/apps-registry/contractspec"
	},
	"exports": {
		".": "./src/index.ts"
	}
}

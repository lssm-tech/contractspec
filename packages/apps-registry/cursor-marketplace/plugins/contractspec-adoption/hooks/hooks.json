{
	"version": 1,
	"hooks": {
		"beforeFileEdit": [
			{
				"type": "command",
				"command": "contractspec connect hook adoption before-file-edit --stdin"
			}
		],
		"beforeShellExecution": [
			{
				"type": "command",
				"command": "contractspec connect hook adoption before-shell-execution --stdin"
			}
		],
		"afterFileEdit": [
			{
				"type": "command",
				"command": "contractspec connect hook adoption after-file-edit --stdin"
			}
		]
	}
}
